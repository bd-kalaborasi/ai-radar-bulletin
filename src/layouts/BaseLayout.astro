---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Daily verified AI news bulletin — zero hallucination, primary sources only.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="masthead">
      <div class="masthead-inner">
        <h1 class="masthead-title">
          <a href="/">AI Radar</a>
        </h1>
        <nav class="masthead-nav">
          <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Latest</a>
          <a href="/archive" aria-current={currentPath.startsWith('/archive') ? 'page' : undefined}>Archive</a>
          <a href="/about" aria-current={currentPath.startsWith('/about') ? 'page' : undefined}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        AI Radar &middot; daily verified bulletin &middot; methodology disclosed at <a href="/about">/about</a>
      </p>
    </footer>
  </body>
</html>
